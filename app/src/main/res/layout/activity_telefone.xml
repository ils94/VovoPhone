<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="5dp"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="0dp"
        android:layout_weight="25"
        android:orientation="horizontal">

        <Button
            android:id="@+id/telcontato1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:layout_weight="50"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="Contato 1"
            android:textSize="20sp" />

        <Button
            android:id="@+id/telcontato2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:layout_weight="50"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="Contato 2"
            android:textSize="20sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="0dp"
        android:layout_weight="25"
        android:orientation="horizontal">

        <Button
            android:id="@+id/telcontato3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:layout_weight="50"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="Contato 3"
            android:textSize="20sp" />

        <Button
            android:id="@+id/telcontato4"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:layout_weight="50"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="Contato 4"
            android:textSize="20sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="0dp"
        android:layout_weight="25"
        android:orientation="horizontal">

        <Button
            android:id="@+id/telcontato5"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:layout_weight="50"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="Contato 5"
            android:textSize="20sp" />

        <Button
            android:id="@+id/telcontato6"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:layout_weight="50"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="Contato 6"
            android:textSize="20sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="0dp"
        android:layout_weight="25"
        android:orientation="horizontal">

        <Button
            android:id="@+id/emergencia"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp"
            android:background="@color/white"
            android:fontFamily="sans-serif-black"
            android:text="EMERGÊNCIA"
            android:textSize="20sp" />

    </LinearLayout>

</LinearLayout>